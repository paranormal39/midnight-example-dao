{
  "name": "@midnight-ntwrk/dao-cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "TS_NODE_TRANSPILE_ONLY=true node --experimental-specifier-resolution=node --loader ts-node/esm src/dao-preprod.ts",
    "start-ps": "docker compose -f proof-server.yml pull && TS_NODE_TRANSPILE_ONLY=true node --experimental-specifier-resolution=node --loader ts-node/esm src/dao-preprod-start-proof-server.ts"
  },
  "dependencies": {
    "@midnight-ntwrk/dao-contract": "*"
  }
}
